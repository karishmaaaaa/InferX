APP_NAME=InferX
ENVIRONMENT=local
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://inferx:inferx@postgres:5432/inferx

# Provider API keys are intentionally blank for local development.
# Add values only in your local .env file, never in source control.
SARVAM_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

OLLAMA_BASE_URL=http://host.docker.internal:11434

# Local dev/test-only bootstrap. Leave disabled unless you want the API container
# to create known local API keys for manual testing or load testing.
BOOTSTRAP_DEV_DATA=false
API_KEY_CACHE_TTL_SECONDS=60
LOCAL_FREE_API_KEY=
LOCAL_PREMIUM_API_KEY=
LOCAL_DEV_USER_EMAIL=local-dev@inferx.internal

ENABLE_DEV_PROVIDER=false
DEV_PROVIDER_LATENCY_MS=0
DEV_PROVIDER_STREAM_CHUNK_DELAY_MS=250
ENABLE_DEMO_CONTROLS=false
ENABLE_OLLAMA_PROVIDER=false
PROVIDER_PRIORITY=dev_echo,dev_backup,ollama,groq,openai,gemini,sarvam
PROVIDER_REQUEST_TIMEOUT_SECONDS=5
PROVIDER_SCORE_INTERVAL_SECONDS=60
PROVIDER_SCORE_WINDOW_SECONDS=300

CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_COOLDOWN_SECONDS=30
PROVIDER_HEALTH_CHECK_INTERVAL_SECONDS=5

SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.88
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_MAX_ENTRIES=250
SEMANTIC_EMBEDDING_DIMENSIONS=256

REQUEST_QUEUE_MAX_SIZE=1000
REQUEST_QUEUE_WORKERS=8
USAGE_WRITER_QUEUE_SIZE=10000
USAGE_WRITER_WORKERS=4

DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT_SECONDS=5

OTEL_SERVICE_NAME=inferx
OTEL_EXPORTER_OTLP_ENDPOINT=
